# TallyDekho Web Portal — Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# Local development
VITE_API_URL=http://localhost:3001/app
VITE_WS_URL=http://localhost:3001

# Production (AWS) — uncomment and set your domain
# VITE_API_URL=https://api.your-domain.com/app
# VITE_WS_URL=https://api.your-domain.com
